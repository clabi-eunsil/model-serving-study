# Langfuse Cloud 또는 self-hosted Langfuse에서 발급받은 API key를 넣는다.
# 실제 secret이므로 이 파일을 복사한 .env는 git에 커밋하지 않는다.
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key

# Langfuse Cloud EU region 예시:
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
#
# Langfuse Cloud US region 예시:
# LANGFUSE_BASE_URL=https://us.cloud.langfuse.com
#
# local/self-hosted 예시:
# LANGFUSE_BASE_URL=http://localhost:3000
#
# 폐쇄망 self-hosted 예시:
# LANGFUSE_BASE_URL=http://langfuse.internal.example:3000
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# 기존 예제나 내부 환경에서 LANGFUSE_HOST를 쓰는 경우도 있다.
# 이 챕터의 Python script는 HOST만 설정되어 있어도 BASE_URL로 변환해 준다.
# 새로 작성할 때는 공식 문서에 맞춰 LANGFUSE_BASE_URL을 우선 사용한다.
# LANGFUSE_HOST=https://cloud.langfuse.com

# OpenAI-compatible endpoint.
# vLLM을 챕터 4 방식으로 띄웠다면 보통 아래 값이다.
OPENAI_BASE_URL=http://127.0.0.1:8000/v1
OPENAI_API_KEY=EMPTY
OPENAI_MODEL=study-model
